# Environment
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_USE_ENTRA_ID=false
AZURE_OPENAI_TOKEN_SCOPE=https://cognitiveservices.azure.com/.default
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_USE_ENTRA_ID=false
AZURE_SPEECH_RESOURCE_ID=
DATABASE_URL=sqlite+aiosqlite:///./sora-videogen.db
MEDIA_DIR=./media
MEDIA_BACKEND=ffmpeg
GSTREAMER_LAUNCH_BINARY=gst-launch-1.0
GSTREAMER_INSPECT_BINARY=gst-inspect-1.0
GSTREAMER_FRAME_SAMPLE_FPS=2

# OpenAI model settings
# For Azure OpenAI, set these to your deployment names.
SUMMARIZER_MODEL=gpt-5-mini
TTS_VOICE=zh-TW-HsiaoYuNeural
SORA_MODEL=sora-2

# Optional Azure Identity environment variables
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_SCENES_PER_PROJECT=300
SCENE_DURATION_SECONDS=12
SORA_VIDEO_SIZE=1280x720

# Video generation retry policy
# VIDEO_GENERATION_MAX_ATTEMPTS counts the initial request plus retries.
# 2 means: first attempt + 1 retry.
VIDEO_GENERATION_MAX_ATTEMPTS=2
VIDEO_GENERATION_RETRY_DELAY_SECONDS=45
